#!/usr/bin/env Rscript
##################报错原因总结###################################
# Harmony 报错通常不是数据问题，而是函数来源和版本不匹配导致的。RunHarmony() 在 harmony、SeuratWrappers 以及 Seurat 的 S3 方法中同时存在，
# 不同版本对参数（如 dims、dims.use）的定义不一致，容易引发 argument matches multiple formal arguments 的错误；同时，
# 部分版本的 SeuratWrappers 并未导出 RunHarmony，会出现函数不存在的报错。因此关键在于明确使用 harmony 包的原生接口、避免混用参数风格，一般不需要重新 merge 数据或刻意降级软件版本。
suppressPackageStartupMessages({
  library(Seurat)
  library(harmony)
  library(ggplot2)
  #library(SeuratWrappers)
})

## =========================
## 1. 参数与路径
## =========================

rds_file <- "/jdfsbjcas1/ST_BJ/P21Z28400N0234/wangning12/1_project/4-multiOmics/RNA/results/mergeSilique/silique_3stage_after_QC_doublet.rds.rds"
outdir   <- "/jdfsbjcas1/ST_BJ/P21Z28400N0234/wangning12/1_project/4-multiOmics/RNA/results/mergeSilique/harmony"

dim.use  <- 20
res.use  <- 0.5
batch.var <- "Stage"   ## 去除的批次变量

dir.create(outdir, recursive = TRUE, showWarnings = FALSE)
setwd(outdir)

## =========================
## 2. 读取对象
## =========================

scRNA <- readRDS(rds_file)

cat("Cells:", ncol(scRNA), "\n")
cat("Stages:\n")
print(table(scRNA[[batch.var]][,1]))

## =========================
## 2.5 去除 Doublet，只保留 Singlet
## =========================

table(scRNA$Doublet)

scRNA <- subset(
  scRNA,
  subset = Doublet == "Singlet"
)

cat("After removing doublets:\n")
cat("Cells:", ncol(scRNA), "\n")
print(table(scRNA[[batch.var]][,1]))


## =========================
## 3. 标准预处理（不动 counts）
## =========================

scRNA <- NormalizeData(scRNA)
scRNA <- FindVariableFeatures(scRNA, nfeatures = 2000)
scRNA <- ScaleData(scRNA)
scRNA <- RunPCA(scRNA, npcs = 30, verbose = FALSE)

## =========================
## 4. Harmony 去批次
## =========================

# scRNA <- RunHarmony(
#   object = scRNA,
#   group.by.vars = batch.var,
#   reduction = "pca",
#   dims.use = 1:dim.use,
#   assay.use = "RNA",
#   verbose = TRUE
# )
# scRNA <- RunHarmony(
#   scRNA,
#   group.by.vars = batch.var,
#   reduction = "pca",
#   dims = 1:dim.use,
#   verbose = TRUE
# )
# scRNA <- SeuratWrappers::RunHarmony(
#   scRNA,
#   group.by.vars = batch.var,
#   reduction = "pca",
#   dims = 1:dim.use,
#   verbose = TRUE
# )
scRNA <- RunHarmony(
  object = scRNA,
  group.by.vars = batch.var,
  reduction = "pca",
  dims.use = 1:dim.use,
  assay.use = "RNA",
  reduction.save = "harmony",
  verbose = TRUE
)

## =========================
## 5. Harmony 空间聚类 + UMAP
## =========================

scRNA <- FindNeighbors(
  scRNA,
  reduction = "harmony",
  dims = 1:dim.use
)

scRNA <- FindClusters(
  scRNA,
  resolution = res.use
)

scRNA <- RunUMAP(
  scRNA,
  reduction = "harmony",
  dims = 1:dim.use
)

## =========================
## 6. 可视化
## =========================

## 6.1 按 cluster
pdf("UMAP_harmony_by_cluster.pdf", width = 6, height = 5)
print(
  DimPlot(
    scRNA,
    reduction = "umap",
    label = TRUE,
    repel = TRUE
  ) + ggtitle("Harmony UMAP by cluster")
)
dev.off()

## 6.2 按 Stage
pdf("UMAP_harmony_by_stage.pdf", width = 6, height = 5)
print(
  DimPlot(
    scRNA,
    reduction = "umap",
    group.by = batch.var
  ) + ggtitle("Harmony UMAP by Stage")
)
dev.off()

## =========================
## 7. 保存对象
## =========================

saveRDS(
  scRNA,
  file = "silique_3stage_after_QC_doublet_harmony.rds"
)

cat(">>> Harmony integration finished.\n")

