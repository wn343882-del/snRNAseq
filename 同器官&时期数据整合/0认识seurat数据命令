#!/usr/bin/env Rscript

suppressPackageStartupMessages({
  library(Seurat)
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  library(patchwork)
  library(ComplexHeatmap)
  library(circlize)
  library(knitr)
})

# ============================================
# 1. 读取数据并检查基本结构
# ============================================

cat("============================================\n")
cat(" 1. 读取数据并检查基本结构\n")
cat("============================================\n")

# 读取RDS文件
rds_path <- "/jdfsbjcas1/ST_BJ/P21Z28400N0234/wangning12/1_project/4-multiOmics/RNA/results/mergeSilique/silique_3stage_after_QC_doublet.rds.rds"
cat("读取文件:", rds_path, "\n")

scRNA <- readRDS(rds_path)
setwd("/jdfsbjcas1/ST_BJ/P21Z28400N0234/wangning12/1_project/4-multiOmics/RNA/results/mergeSilique/summaryRDS")
cat("\n[基本信息]\n")
cat("对象类型:", class(scRNA), "\n")
cat("细胞总数:", ncol(scRNA), "\n")
cat("基因总数:", nrow(scRNA), "\n")
cat("数据维度:", dim(scRNA), "\n")

# ============================================
# 2. 检查数据层级结构
# ============================================

cat("\n============================================\n")
cat(" 2. 检查数据层级结构\n")
cat("============================================\n")

cat("\n[Seurat对象的主要slot]\n")
slot_names <- slotNames(scRNA)
cat("可用slot数:", length(slot_names), "\n")
cat("Slot列表:\n")
for(slot in slot_names) {
  slot_obj <- slot(scRNA, slot)
  cat(sprintf("  %-20s: %-15s (维度: %s)\n", 
              slot, 
              class(slot_obj)[1],
              ifelse(is.null(dim(slot_obj)), 
                     length(slot_obj), 
                     paste(dim(slot_obj), collapse = " x "))))
}

# ============================================
# 3. 详细检查Assays
# ============================================

cat("\n============================================\n")
cat(" 3. 检查Assays数据\n")
cat("============================================\n")

assays_list <- Assays(scRNA)
cat("Assays数量:", length(assays_list), "\n")
cat("Assays名称:", paste(assays_list, collapse = ", "), "\n")

for(assay_name in assays_list) {
  cat("\n---", assay_name, "---\n")
  assay_obj <- GetAssay(scRNA, assay = assay_name)
  
  # 检查counts矩阵
  if(!is.null(assay_obj@counts)) {
    counts_mat <- assay_obj@counts
    cat("Counts矩阵维度:", dim(counts_mat), "\n")
    cat("Counts矩阵稀疏度:", round(100 * (1 - length(counts_mat@x) / prod(dim(counts_mat))), 2), "%\n")
    cat("非零值总数:", length(counts_mat@x), "\n")
    
    # 统计表达量
    if(length(counts_mat@x) > 0) {
      cat("Counts统计:\n")
      cat("  最小值:", min(counts_mat@x), "\n")
      cat("  最大值:", max(counts_mat@x), "\n")
      cat("  中位数:", median(counts_mat@x), "\n")
      cat("  平均值:", round(mean(counts_mat@x), 2), "\n")
    }
  }
  
  # 检查data矩阵
  if(!is.null(assay_obj@data)) {
    data_mat <- assay_obj@data
    cat("Data矩阵维度:", dim(data_mat), "\n")
    if(is(data_mat, "dgCMatrix")) {
      cat("Data矩阵稀疏度:", round(100 * (1 - length(data_mat@x) / prod(dim(data_mat))), 2), "%\n")
    }
  }
  
  # 检查scale.data矩阵
  if(!is.null(assay_obj@scale.data)) {
    scale_mat <- assay_obj@scale.data
    cat("Scale.data维度:", dim(scale_mat), "\n")
  }
  
  # 检查variable features
  var_features <- VariableFeatures(assay_obj)
  if(length(var_features) > 0) {
    cat("可变基因数:", length(var_features), "\n")
    cat("前10个可变基因:", paste(head(var_features, 10), collapse = ", "), "\n")
  }
}

# ============================================
# 4. 检查元数据(metadata)
# ============================================

cat("\n============================================\n")
cat(" 4. 检查元数据(metadata)\n")
cat("============================================\n")

meta_data <- scRNA@meta.data
cat("元数据维度:", dim(meta_data), "\n")
cat("元数据列名:\n")
print(colnames(meta_data))

cat("\n[各列数据类型和示例值]\n")
for(col in colnames(meta_data)) {
  col_data <- meta_data[[col]]
  cat(sprintf("\n%-20s:", col))
  cat(" 类型:", class(col_data)[1])
  if(is.factor(col_data) || is.character(col_data)) {
    cat(", 水平数:", length(unique(col_data)))
    cat(", 示例:", paste(head(unique(col_data), 3), collapse = ", "))
  } else if(is.numeric(col_data)) {
    cat(", 范围:", sprintf("[%.2f, %.2f]", min(col_data), max(col_data)))
    cat(", 均值:", round(mean(col_data), 2))
  }
}

# ============================================
# 5. 检查批次(batch)信息
# ============================================

cat("\n============================================\n")
cat(" 5. 检查批次(batch)信息\n")
cat("============================================\n")

# 查找可能的批次列
batch_candidates <- c("batch", "Batch", "batch_id", "orig.ident", "sample", "Sample", "library", "Library")
found_batch_cols <- intersect(batch_candidates, colnames(meta_data))

if(length(found_batch_cols) > 0) {
  cat("找到批次列:", paste(found_batch_cols, collapse = ", "), "\n")
  
  for(batch_col in found_batch_cols) {
    cat("\n---", batch_col, "---\n")
    batch_info <- table(meta_data[[batch_col]])
    cat("批次总数:", length(batch_info), "\n")
    cat("批次分布:\n")
    print(batch_info)
    cat("批次细胞数统计:\n")
    print(summary(as.numeric(batch_info)))
  }
} else {
  cat("未找到标准批次列，显示所有分类列的分布:\n")
  categorical_cols <- colnames(meta_data)[sapply(meta_data, function(x) is.factor(x) || is.character(x))]
  for(col in categorical_cols[1:min(5, length(categorical_cols))]) {
    cat("\n---", col, "---\n")
    print(table(meta_data[[col]]))
  }
}

# ============================================
# 6. 检查双胞(Doublet)信息
# ============================================

cat("\n============================================\n")
cat(" 6. 检查双胞(Doublet)信息\n")
cat("============================================\n")

# 查找双胞相关列
doublet_candidates <- c("Doublet", "doublet", "DF.classifications", "scDblFinder.class")
found_doublet_cols <- intersect(doublet_candidates, colnames(meta_data))

if(length(found_doublet_cols) > 0) {
  cat("找到双胞列:", paste(found_doublet_cols, collapse = ", "), "\n")
  
  for(doublet_col in found_doublet_cols) {
    cat("\n---", doublet_col, "---\n")
    doublet_info <- table(meta_data[[doublet_col]])
    cat("双胞状态分布:\n")
    print(doublet_info)
    
    # 计算比例
    doublet_rate <- ifelse("Doublet" %in% names(doublet_info), 
                          doublet_info["Doublet"] / sum(doublet_info), 
                          0)
    cat("双胞比例:", round(doublet_rate * 100, 2), "%\n")
  }
} else {
  cat("未找到双胞列，检查是否有相关pattern的列:\n")
  potential_doublet_cols <- grep("doublet|Doublet|DF", colnames(meta_data), ignore.case = TRUE, value = TRUE)
  if(length(potential_doublet_cols) > 0) {
    cat("可能的双胞相关列:", paste(potential_doublet_cols, collapse = ", "), "\n")
  } else {
    cat("未发现双胞相关列\n")
  }
}

# ============================================
# 7. 双胞描述性统计分析
# ============================================

cat("\n============================================\n")
cat(" 7. 双胞描述性统计分析\n")
cat("============================================\n")

if(length(found_doublet_cols) > 0) {
  doublet_col <- found_doublet_cols[1]
  doublet_cells <- meta_data[[doublet_col]] == "Doublet"
  singlet_cells <- meta_data[[doublet_col]] == "Singlet"
  
  # 只分析同时有双胞和单胞的数据
  if(sum(doublet_cells, na.rm = TRUE) > 0 && sum(singlet_cells, na.rm = TRUE) > 0) {
    
    cat("\n[双胞与单胞的QC指标比较]\n")
    
    qc_metrics <- c("nCount_RNA", "nFeature_RNA", "percent.mt", "percent.C")
    available_qc <- intersect(qc_metrics, colnames(meta_data))
    
    comparison_stats <- data.frame(
      Metric = character(),
      Group = character(),
      Mean = numeric(),
      Median = numeric(),
      SD = numeric(),
      Min = numeric(),
      Max = numeric(),
      stringsAsFactors = FALSE
    )
    
    for(metric in available_qc) {
      # 双胞统计
      doublet_values <- meta_data[doublet_cells, metric]
      singlet_values <- meta_data[singlet_cells, metric]
      
      comparison_stats <- rbind(comparison_stats, 
                               data.frame(
                                 Metric = metric,
                                 Group = "Doublet",
                                 Mean = mean(doublet_values, na.rm = TRUE),
                                 Median = median(doublet_values, na.rm = TRUE),
                                 SD = sd(doublet_values, na.rm = TRUE),
                                 Min = min(doublet_values, na.rm = TRUE),
                                 Max = max(doublet_values, na.rm = TRUE)
                               ))
      
      comparison_stats <- rbind(comparison_stats, 
                               data.frame(
                                 Metric = metric,
                                 Group = "Singlet",
                                 Mean = mean(singlet_values, na.rm = TRUE),
                                 Median = median(singlet_values, na.rm = TRUE),
                                 SD = sd(singlet_values, na.rm = TRUE),
                                 Min = min(singlet_values, na.rm = TRUE),
                                 Max = max(singlet_values, na.rm = TRUE)
                               ))
    }
    
    # 格式化输出
    comparison_wide <- comparison_stats %>%
      pivot_wider(
        id_cols = Metric,
        names_from = Group,
        values_from = c(Mean, Median, SD, Min, Max)
      )
    
    cat("\n双胞 vs 单胞统计比较:\n")
    print(comparison_wide)
    
    # Wilcoxon检验
    cat("\n[统计检验 - Wilcoxon秩和检验]\n")
    test_results <- data.frame(
      Metric = character(),
      p_value = numeric(),
      effect_size = numeric(),
      stringsAsFactors = FALSE
    )
    
    for(metric in available_qc) {
      doublet_values <- meta_data[doublet_cells, metric]
      singlet_values <- meta_data[singlet_cells, metric]
      
      if(length(doublet_values) > 1 && length(singlet_values) > 1) {
        test <- wilcox.test(doublet_values, singlet_values)
        # 计算效应量（Cohen's d）
        pooled_sd <- sqrt(((length(doublet_values)-1)*var(doublet_values) + 
                           (length(singlet_values)-1)*var(singlet_values)) /
                          (length(doublet_values) + length(singlet_values) - 2))
        effect_size <- (mean(doublet_values) - mean(singlet_values)) / pooled_sd
        
        test_results <- rbind(test_results,
                             data.frame(
                               Metric = metric,
                               p_value = test$p.value,
                               effect_size = effect_size
                             ))
      }
    }
    
    if(nrow(test_results) > 0) {
      test_results$p_adj <- p.adjust(test_results$p_value, method = "BH")
      test_results$significance <- ifelse(test_results$p_adj < 0.001, "***",
                                         ifelse(test_results$p_adj < 0.01, "**",
                                                ifelse(test_results$p_adj < 0.05, "*", "ns")))
      print(test_results)
    }
    
    # 双胞在各批次中的分布
    if(length(found_batch_cols) > 0) {
      batch_col <- found_batch_cols[1]
      cat("\n[双胞在各批次中的分布]\n")
      
      doublet_by_batch <- table(
        meta_data[[batch_col]],
        meta_data[[doublet_col]]
      )
      
      print(doublet_by_batch)
      
      # 计算每个批次的双胞率
      doublet_rate_by_batch <- prop.table(doublet_by_batch, margin = 1)
      cat("\n各批次双胞率:\n")
      print(round(doublet_rate_by_batch[, "Doublet"] * 100, 2))
    }
    
    # 双胞在各stage中的分布
    if("Stage" %in% colnames(meta_data)) {
      cat("\n[双胞在各发育阶段中的分布]\n")
      
      doublet_by_stage <- table(
        meta_data$Stage,
        meta_data[[doublet_col]]
      )
      
      print(doublet_by_stage)
      
      # 计算每个stage的双胞率
      doublet_rate_by_stage <- prop.table(doublet_by_stage, margin = 1)
      cat("\n各阶段双胞率:\n")
      print(round(doublet_rate_by_stage[, "Doublet"] * 100, 2))
    }
    
  } else {
    cat("警告: 未找到足够的数据进行双胞比较分析\n")
  }
} else {
  cat("无法进行双胞分析: 未找到双胞信息列\n")
}

# ============================================
# 8. 检查降维信息
# ============================================

cat("\n============================================\n")
cat(" 8. 检查降维信息\n")
cat("============================================\n")

# 检查PCA
if(!is.null(scRNA@reductions$pca)) {
  pca_obj <- scRNA@reductions$pca
  cat("PCA维度:", dim(pca_obj@cell.embeddings), "\n")
  cat("可用PCA维度数:", ncol(pca_obj@cell.embeddings), "\n")
  cat("PCA特征值(前10个):", head(pca_obj@stdev, 10), "\n")
  
  # 计算方差解释比例
  var_explained <- (pca_obj@stdev^2) / sum(pca_obj@stdev^2) * 100
  cat("\nPCA方差解释比例(前10个主成分):\n")
  print(round(var_explained[1:10], 2))
  cat("前10个PC累计解释方差:", round(sum(var_explained[1:10]), 2), "%\n")
} else {
  cat("未找到PCA降维结果\n")
}

# 检查UMAP
if(!is.null(scRNA@reductions$umap)) {
  umap_obj <- scRNA@reductions$umap
  cat("\nUMAP维度:", dim(umap_obj@cell.embeddings), "\n")
  cat("UMAP参数:\n")
  print(umap_obj@misc)
} else {
  cat("\n未找到UMAP降维结果\n")
}

# ============================================
# 9. 检查聚类信息
# ============================================

cat("\n============================================\n")
cat(" 9. 检查聚类信息\n")
cat("============================================\n")

# 查找聚类列
cluster_cols <- grep("cluster|Cluster|seurat_clusters|ident", colnames(meta_data), 
                     ignore.case = TRUE, value = TRUE)

if(length(cluster_cols) > 0) {
  cat("找到聚类列:", paste(cluster_cols, collapse = ", "), "\n")
  
  for(cluster_col in cluster_cols) {
    cat("\n---", cluster_col, "---\n")
    cluster_info <- table(meta_data[[cluster_col]])
    cat("聚类数:", length(cluster_info), "\n")
    cat("聚类大小分布:\n")
    print(cluster_info)
    
    # 统计摘要
    cluster_sizes <- as.numeric(cluster_info)
    cat("\n聚类大小统计:\n")
    print(summary(cluster_sizes))
    
    # 如果同时有双胞信息，分析双胞在聚类中的分布
    if(length(found_doublet_cols) > 0) {
      doublet_col <- found_doublet_cols[1]
      doublet_by_cluster <- table(
        meta_data[[cluster_col]],
        meta_data[[doublet_col]]
      )
      
      if("Doublet" %in% colnames(doublet_by_cluster)) {
        cat("\n双胞在各聚类中的分布:\n")
        cluster_doublet_rates <- doublet_by_cluster[, "Doublet"] / rowSums(doublet_by_cluster)
        print(round(cluster_doublet_rates * 100, 2))
        
        # 找出双胞率最高的聚类
        high_doublet_clusters <- names(sort(cluster_doublet_rates, decreasing = TRUE)[1:3])
        cat("\n双胞率最高的3个聚类:\n")
        for(clust in high_doublet_clusters) {
          cat(sprintf("  聚类 %s: %.1f%% (%d/%d)\n", 
                      clust, 
                      cluster_doublet_rates[clust] * 100,
                      doublet_by_cluster[clust, "Doublet"],
                      sum(doublet_by_cluster[clust, ])))
        }
      }
    }
  }
} else {
  cat("未找到聚类信息列\n")
}

# ============================================
# 10. 保存分析结果
# ============================================

cat("\n============================================\n")
cat(" 10. 生成汇总报告和可视化\n")
cat("============================================\n")

# 创建输出目录
output_dir <- "data_structure_analysis"
dir.create(output_dir, showWarnings = FALSE)

# 保存元数据
write.csv(meta_data, file.path(output_dir, "metadata_detailed.csv"), row.names = TRUE)

# 保存双胞分析结果
if(length(found_doublet_cols) > 0) {
  doublet_summary <- data.frame(
    Total_cells = ncol(scRNA),
    Doublet_cells = sum(meta_data[[found_doublet_cols[1]]] == "Doublet", na.rm = TRUE),
    Singlet_cells = sum(meta_data[[found_doublet_cols[1]]] == "Singlet", na.rm = TRUE),
    Doublet_rate = sum(meta_data[[found_doublet_cols[1]]] == "Doublet", na.rm = TRUE) / ncol(scRNA)
  )
  write.csv(doublet_summary, file.path(output_dir, "doublet_summary.csv"), row.names = FALSE)
}

# 生成可视化报告
pdf(file.path(output_dir, "data_structure_visualization.pdf"), width = 12, height = 10)

# 1. 批次分布
if(length(found_batch_cols) > 0) {
  batch_col <- found_batch_cols[1]
  p1 <- ggplot(meta_data, aes(x = .data[[batch_col]], fill = .data[[batch_col]])) +
    geom_bar() +
    labs(title = "Cell Distribution by Batch",
         x = "Batch", y = "Number of Cells") +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))
  print(p1)
}

# 2. 双胞分布
if(length(found_doublet_cols) > 0) {
  doublet_col <- found_doublet_cols[1]
  p2 <- ggplot(meta_data, aes(x = .data[[doublet_col]], fill = .data[[doublet_col]])) +
    geom_bar() +
    labs(title = "Doublet Distribution",
         x = "Doublet Status", y = "Number of Cells") +
    theme_minimal()
  print(p2)
}

# 3. QC指标分布
if(length(intersect(c("nCount_RNA", "nFeature_RNA"), colnames(meta_data))) == 2) {
  p3 <- ggplot(meta_data, aes(x = nCount_RNA, y = nFeature_RNA)) +
    geom_point(alpha = 0.3, size = 0.5) +
    scale_x_log10() + scale_y_log10() +
    labs(title = "UMI vs Gene Counts",
         x = "UMI Count (log10)", y = "Gene Count (log10)") +
    theme_minimal()
  print(p3)
}

# 4. 双胞与单胞的QC比较箱线图
if(length(found_doublet_cols) > 0 && length(intersect(qc_metrics, colnames(meta_data))) > 0) {
  for(metric in intersect(qc_metrics, colnames(meta_data))) {
    p <- ggplot(meta_data, aes(x = .data[[found_doublet_cols[1]]], y = .data[[metric]], 
                               fill = .data[[found_doublet_cols[1]]])) +
      geom_boxplot(outlier.size = 0.5) +
      labs(title = paste(metric, "by Doublet Status"),
           x = "Doublet Status", y = metric) +
      theme_minimal()
    
    if(metric %in% c("nCount_RNA", "nFeature_RNA")) {
      p <- p + scale_y_log10()
    }
    
    print(p)
  }
}

dev.off()

cat("\n分析完成！结果已保存到目录:", output_dir, "\n")
cat("生成的文件:\n")
cat("  - metadata_detailed.csv: 详细元数据\n")
cat("  - doublet_summary.csv: 双胞汇总\n")
cat("  - data_structure_visualization.pdf: 可视化报告\n")

cat("\n[关键发现总结]\n")
cat("1. 细胞总数:", ncol(scRNA), "\n")
cat("2. 基因总数:", nrow(scRNA), "\n")
cat("3. 批次列:", ifelse(length(found_batch_cols) > 0, 
                       paste(found_batch_cols, collapse = ", "), "未找到"), "\n")
cat("4. 双胞列:", ifelse(length(found_doublet_cols) > 0, 
                        paste(found_doublet_cols, collapse = ", "), "未找到"), "\n")
if(length(found_doublet_cols) > 0) {
  doublet_rate_val <- ifelse("Doublet" %in% meta_data[[found_doublet_cols[1]]], 
                            sum(meta_data[[found_doublet_cols[1]]] == "Doublet") / ncol(scRNA),
                            0)
  cat("5. 双胞比例:", round(doublet_rate_val * 100, 2), "%\n")
}
